<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💰 Split Bill App"
        android:textSize="22sp"
        android:textStyle="bold"/>

    <EditText
        android:id="@+id/inputTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Total Tagihan"
        android:inputType="number"
        android:layout_marginTop="15dp"/>

    <EditText
        android:id="@+id/inputOrang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Jumlah Orang"
        android:inputType="number"
        android:layout_marginTop="10dp"/>

    <EditText
        android:id="@+id/inputPajak"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Pajak (%) (opsional)"
        android:inputType="number"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/btnHitung"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hitung Sekarang"
        android:layout_marginTop="15dp"/>

    <TextView
        android:id="@+id/txtHasil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hasil akan muncul di sini"
        android:textSize="18sp"
        android:layout_marginTop="20dp"/>

</LinearLayout>